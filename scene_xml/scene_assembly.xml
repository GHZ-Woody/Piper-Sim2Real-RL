<mujoco model="piper_scene">
    <include file="piper.xml"/>
    
    <statistic center="0 0 0.1" extent="0.4"/>
    
    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
        <global azimuth="120" elevation="-20"/>
    </visual>
    
    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
        <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
        <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
        
        <material name="table_mat" rgba="0.8 0.8 0.8 1" reflectance="0.1"/>
        <material name="peg_mat" rgba="1.0 0.4 0.4 1" reflectance="0.5"/>     <material name="hole_mat" rgba="0.2 0.6 1.0 1" reflectance="0.3"/>    </asset>
    
    <worldbody>
        <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
        <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
        
        # ====================================================================
        # 1. 实验操作台（Table）
        # ====================================================================
        <body name="table" pos="0.3 0 0.1">
            <geom name="table_top" type="box" size="0.2 0.3 0.05" material="table_mat"/>
        </body>

        # ====================================================================
        # 2. 目标基座（带孔的 Hole）
        # ====================================================================
        <body name="base_hole" pos="0.3 -0.1 0.15">
            <geom name="hole_front" type="box" pos="0.04 0 0.02" size="0.01 0.05 0.02" material="hole_mat"/>
            <geom name="hole_back" type="box" pos="-0.04 0 0.02" size="0.01 0.05 0.02" material="hole_mat"/>
            <geom name="hole_left" type="box" pos="0 0.04 0.02" size="0.03 0.01 0.02" material="hole_mat"/>
            <geom name="hole_right" type="box" pos="0 -0.04 0.02" size="0.03 0.01 0.02" material="hole_mat"/>
        </body>

        # ====================================================================
        # 3. 待抓取的插销（Peg）
        # ====================================================================
        <body name="peg" pos="0.3 0.1 0.2">
            <freejoint name="peg_joint"/>
            <geom name="peg_geom" type="box" size="0.01 0.01 0.03" density="1000" material="peg_mat"/>
        </body>

        <body name="mocap_target" mocap="true" pos="0.2 0 0.2">
            <geom type="sphere" size="0.01" rgba="0 1 0 0.5"/> 
        </body>
        
    </worldbody>
    <equality>
        <weld body1="mocap_target" body2="link6" relpose="0 0 0 1 0 0 0"/>
    </equality>
</mujoco>